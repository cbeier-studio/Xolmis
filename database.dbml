    state_id integer [ref: > gazetteer.site_id]
    municipality_id integer [ref: > gazetteer.site_id]
    institution_id integer [ref: > institutions.institution_id]
    department varchar(100)
    job_role varchar(100)
    lattes_uri varchar(30)
    orcid_uri varchar(30)
    twitter_uri varchar(50)
    instagram_uri varchar(50)
    website_uri varchar(100)
    profile_color varchar(30)
    notes text
    profile_image blob
    ~audit_fields

    indexes {
        birth_date [name: 'idx_people_birthday']
        citation [name: 'idx_people_citation', note: 'COLLATE NOCASE']
        full_name [name: 'idx_people_fullname', note: 'COLLATE NOCASE']
    }
}

